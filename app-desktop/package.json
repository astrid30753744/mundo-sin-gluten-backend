{
  "name": "mundo-sin-gluten-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.mundosingluten.pos",
    "productName": "Mundo Sin Gluten",
    "win": { "target": "nsis", "icon": "assets/icon.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "shortcutName": "Mundo Sin Gluten" },
    "files": ["main.js", "preload.js", "src/**/*", "assets/**/*"]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
